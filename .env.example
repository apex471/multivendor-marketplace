# =============================================================================
# .env.example  --  Template for all environment variables used by this app.
#
# LOCAL DEV:   Copy this file to .env.local and fill in real values.
#              .env.local is gitignored and will NEVER be committed.
#
# NETLIFY:     Site Settings > Environment Variables > Add a variable
#
# WARNING:     Do NOT put real credentials in this file. It IS in git.
# =============================================================================

# -- MongoDB Atlas -------------------------------------------------------------
# cloud.mongodb.com > your cluster > Connect > Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/clw-marketplace?retryWrites=true&w=majority&appName=Cluster

# -- JWT Authentication --------------------------------------------------------
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_EXPIRE=7d

# -- App URLs ------------------------------------------------------------------
# Replace with your real Netlify domain after the first successful deploy
NEXT_PUBLIC_APP_URL=https://your-site.netlify.app
NEXT_PUBLIC_API_URL=https://your-site.netlify.app/api
NEXT_PUBLIC_APP_NAME=CLW Marketplace

# -- Google OAuth (optional) ---------------------------------------------------
# console.cloud.google.com > APIs and Services > Credentials
# Leave blank to disable Google login (the app degrades gracefully)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -- Maps (optional) -----------------------------------------------------------
# Used by the Store Locator page. Leave blank to disable the map widget.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_access_token

# -- Email SMTP (optional) -----------------------------------------------------
# Sends OTP verification codes to vendors, brands, and logistics users.
# Without SMTP, codes are printed to the server console (dev fallback only).
# Gmail: myaccount.google.com/apppasswords to create an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# -- Stripe (optional) ---------------------------------------------------------
# Payment processing. Leave blank if not yet integrated.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
