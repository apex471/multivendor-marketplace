# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  Copy to .env.local for local dev, then add each key inside
#                  Netlify → Site Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get from Atlas → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/clw-marketplace?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_EXPIRE=7d

# ── App URL (replace with your Netlify domain) ────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.netlify.app
NEXT_PUBLIC_API_URL=https://your-app.netlify.app/api
NEXT_PUBLIC_APP_NAME=CLW Marketplace

# ── Google OAuth ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Google Maps / Mapbox ──────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...








































































































































































































































































